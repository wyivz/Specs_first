OPENAI_API_KEY=
GEMINI_API_KEY=
REDIS_URL=redis://localhost:6379/0
OBSIDIAN_VAULT_PATH=./vault_output
# OpenAI: Structured Output only (Phase 4 arbitration / YAML lock)
DEFAULT_OPENAI_MODEL=gpt-4o-mini
# Gemini: massive text ingestion + multimodal OCR (Phase 1/2/3)
DEFAULT_GEMINI_MODEL=gemini-1.5-flash
SPECS_FIRST_MODE=mock

# --- Collection layer (real mode) ---
# Global minimum spacing between outbound HTTP/platform requests (seconds)
COLLECTION_MIN_INTERVAL_SECONDS=1.0
# Bilibili comment pagination delay (seconds per page; keep >= 3 for safety)
BILIBILI_COMMENT_PAGE_DELAY_SECONDS=3.0
# YouTube comment downloader random backoff range (seconds)
YOUTUBE_COMMENT_DELAY_MIN=1.0
YOUTUBE_COMMENT_DELAY_MAX=3.0
YOUTUBE_COMMENT_MAX_PER_VIDEO=20
BILIBILI_MAX_VIDEOS_PER_SKU=2
BILIBILI_MAX_COMMENTS_PER_VIDEO=50

# Bilibili cookies — required for CC subtitles + comments via bilibili-api-python
# Copy from browser DevTools → Application → Cookies → bilibili.com
# NEVER commit real values; keep in local .env only
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_DEDEUSERID=
BILIBILI_BUVID3=
