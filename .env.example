OPENAI_API_KEY=
GEMINI_API_KEY=
REDIS_URL=redis://localhost:6379/0
OBSIDIAN_VAULT_PATH=./vault_output
# OpenAI: Structured Output only (Phase 4 arbitration / YAML lock)
DEFAULT_OPENAI_MODEL=gpt-4o-mini
# Gemini: massive text ingestion + multimodal OCR (Phase 1/2/3)
# GA default: gemini-3.5-flash (see https://ai.google.dev/gemini-api/docs/models/gemini-3.5-flash)
DEFAULT_GEMINI_MODEL=gemini-3.5-flash
# Optional override for Gemini 3.x thinking: minimal | low | medium | high
# Probe/health checks always use minimal; extraction tasks default to low.
GEMINI_THINKING_LEVEL=low
SPECS_FIRST_MODE=mock

# Gemini context caching (Phase 1/2): avoid re-billing the same huge
# corpus on every retry attempt. No-op below the char floor or if the
# model/account does not support caching.
GEMINI_CONTEXT_CACHE_ENABLED=true
GEMINI_CONTEXT_CACHE_MIN_CHARS=6000
GEMINI_CONTEXT_CACHE_TTL_SECONDS=300

# --- Collection layer (real mode) ---
# Global minimum spacing between outbound HTTP/platform requests (seconds)
COLLECTION_MIN_INTERVAL_SECONDS=1.0
# Ecommerce (JD/Taobao) spacing — higher = more human-like, fewer frequency controls
ECOMMERCE_MIN_INTERVAL_SECONDS=3.0
# Wall-clock cap for Phase 3 price collection per SKU (seconds)
ECOMMERCE_COLLECT_TIMEOUT_SECONDS=300
# Fetch JD/Taobao/Bilibili/Forum sources in parallel (per-platform rate limits still apply)
COLLECTION_PARALLEL_PLATFORMS=true
# Max product detail URLs fetched per platform per SKU (price/specs/probe)
ECOMMERCE_MAX_URLS_PER_PLATFORM=2
# Bilibili comment pagination delay (seconds per page; keep >= 3 for safety)
BILIBILI_COMMENT_PAGE_DELAY_SECONDS=3.0
# YouTube comment downloader random backoff range (seconds)
YOUTUBE_COMMENT_DELAY_MIN=1.0
YOUTUBE_COMMENT_DELAY_MAX=3.0
YOUTUBE_COMMENT_MAX_PER_VIDEO=20
# Last resort when captions are blocked: yt-dlp + local ASR (requires yt-dlp + funasr/faster-whisper)
YOUTUBE_ASR_FALLBACK=false
# Use Playwright in-page fetch for YouTube captions (PoToken-safe path; recommended)
YOUTUBE_BROWSER_TRANSCRIPT=true
# Optional YouTube cookies from logged-in browser (improves PoToken / bot-check success)
YOUTUBE_COOKIE=
BILIBILI_MAX_VIDEOS_PER_SKU=2
BILIBILI_MAX_COMMENTS_PER_VIDEO=50

# Bilibili cookies — required for CC subtitles + comments via bilibili-api-python
# Copy from browser DevTools → Application → Cookies → bilibili.com
# NEVER commit real values; keep in local .env only
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_DEDEUSERID=
BILIBILI_BUVID3=

# When a Bilibili video has no native CC subtitle, fall back to downloading
# the audio (yt-dlp) and transcribing locally (funasr/faster-whisper).
# No-op if those packages are not installed. Set to false to disable.
BILIBILI_ASR_FALLBACK=true

# Taobao/Tmall cookies — required for signed mtop API (detail desc, price blocks)
# Copy the full Cookie header from browser DevTools while logged in to taobao.com
# or tmall.com (Application → Cookies → copy as string or use a Cookie export extension).
# Minimum for signing: _m_h5_tk (or set TAOBAO_M_H5_TK to the token value only).
# NEVER commit real values; keep in local .env only
TAOBAO_COOKIE=
TAOBAO_M_H5_TK=

# JD cookies — recommended for price/spec microservices (pt_key, pt_pin, __jda, etc.)
# Log in at jd.com, copy Cookie header from DevTools. Mainland IP recommended.
# NEVER commit real values; keep in local .env only
JD_COOKIE=

# Reddit cookies — optional; enables auto site:reddit.com forum search in real mode.
# Log in at reddit.com, copy Cookie header from DevTools (reddit_session, token_v2, etc.).
# Without this, Reddit auto-search is skipped; pasted Reddit thread URLs still work.
# NEVER commit real values; keep in local .env only
REDDIT_COOKIE=

# Platform smoke / live-run URLs (override for your SKU and review videos)
# These are for scripts/smoke_platforms.py connectivity probes ONLY — the real
# comparison pipeline discovers JD/Taobao/Bilibili/YouTube links via search.
SMOKE_JD_URL=https://item.jd.com/100012043978.html
SMOKE_TAOBAO_ITEM_ID=520813140663
# Leave empty to skip Bilibili API smoke; any value is only for health-check, not required for runs
SMOKE_BILIBILI_BVID=
SMOKE_YOUTUBE_URL=https://www.youtube.com/watch?v=jNQXAC9IVRw

# Optional: extra pinned URLs merged into a run (comma or newline separated). Leave empty for search-only.
OPTIONAL_SOURCE_URLS=

# Human-readable collection logs (vault_output/collection_trace_<task_id>.log)
COLLECTION_TRACE=true
COLLECTION_TRACE_DIR=./vault_output
